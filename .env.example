# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Your deployment URL (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Database connection
# Local development: file:./sqlite.db
# Production (Turso): libsql://your-db-name.turso.io
DATABASE_URL=file:./sqlite.db

# Turso auth token (required for production, not needed for local file:// URLs)
# DATABASE_AUTH_TOKEN=
